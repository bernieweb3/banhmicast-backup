# BanhMiCast CRE Workflow — Environment Variables
# Copy this file to .env and fill in values before running simulation.

# Required for on-chain write simulation (--broadcast flag)
# Leave empty if only doing dry-run simulation (default)
CRE_ETH_PRIVATE_KEY=

# Optional: Override Sepolia RPC URL (uses public node by default)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
